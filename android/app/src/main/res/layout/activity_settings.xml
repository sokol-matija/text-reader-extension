<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            style="@style/TextReader.Label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_url_label"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/urlInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:background="@drawable/input_bg"
            android:padding="12dp"
            android:inputType="textUri"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_placeholder"
            android:hint="@string/settings_url_hint"
            android:layout_marginBottom="16dp" />

        <TextView
            style="@style/TextReader.Label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_voice_label"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/voiceSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:background="@drawable/input_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="16dp" />

        <TextView
            style="@style/TextReader.Label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_model_label"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/modelInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:background="@drawable/input_bg"
            android:padding="12dp"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_placeholder"
            android:hint="@string/settings_model_hint"
            android:layout_marginBottom="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            style="@style/TextReader.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_save"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTest"
            style="@style/TextReader.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_test" />
    </LinearLayout>
</ScrollView>
